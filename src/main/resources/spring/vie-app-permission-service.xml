<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:context="http://www.springframework.org/schema/context"
	xmlns:aop="http://www.springframework.org/schema/aop" xmlns:mvc="http://www.springframework.org/schema/mvc"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
						http://www.springframework.org/schema/beans/spring-beans-4.0.xsd ">

	<bean id="userService" class="com.iflytek.vie.app.provider.impl.permission.UserServiceImpl">
		<property name="permissionURL" value="${permissionURL}"/>
	</bean>
	
	<bean id="groupAuthService" class="com.iflytek.vie.app.provider.impl.permission.GroupAuthServiceImpl">
		<property name="permissionURL" value="${permissionURL}"/>
	</bean>
	
	<bean id="functionAuthService" class="com.iflytek.vie.app.provider.impl.permission.FunctionAuthServiceImpl">
		<property name="permissionURL" value="${permissionURL}"/>
	</bean>
	
	<bean id="dataAuthService" class="com.iflytek.vie.app.provider.impl.permission.DataAuthServiceImpl">
		<property name="permissionURL" value="${permissionURL}"/>
	</bean>
	
	<bean id="logService" class="com.iflytek.vie.app.provider.impl.permission.LogServiceImpl">
		<property name="permissionURL" value="${permissionURL}"/>
	</bean>
	
	<bean id="systemService" class="com.iflytek.vie.app.provider.impl.permission.SystemServiceImpl">
		<property name="permissionURL" value="${permissionURL}"/>
	</bean>
	
	<bean id="organizationService" class="com.iflytek.vie.app.provider.impl.permission.OrganizationServiceImpl">
		<property name="permissionURL" value="${permissionURL}"/>
	</bean>

</beans>