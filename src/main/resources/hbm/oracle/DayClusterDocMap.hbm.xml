<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.iflytek.vie.app.pojo.datamining">
    <class name="DayClusterDocMap"
           table="DAY_CLUSTER_DOCID_MAP">
        <id name="id" type="java.lang.Long">
            <column name="ID">
                <comment>id</comment>
            </column>
            <generator class="sequence">
                <param name="sequence">
                    DAY_CLUSTER_DOCID_MAP_SEQ
                </param>
            </generator>
        </id>
        <property name="dayClusterId" type="java.lang.Long">
            <column name="DAY_CLUSTERID"></column>
        </property>
        <property name="cluId" type="int">
            <column name="CLUID"></column>
        </property>
        <property name="docString" type="text">
            <column name="DOCID_STRING"></column>
        </property>

    </class>

</hibernate-mapping>