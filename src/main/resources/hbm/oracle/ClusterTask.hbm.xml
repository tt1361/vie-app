<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.iflytek.vie.app.provider.pojo">
    <class name="ClusterTask"
           table="TOGATHER_TASK">

        <id name="taskId" type="java.lang.Long">
            <column name="TASK_ID">
            </column>
            <generator class="sequence">
                <param name="sequence">
                    TOGATHER_TASK_SEQUENCE
                </param>
            </generator>
        </id>

        <property name="togatherId" type="java.lang.Long">
            <column name="TOGATHER_ID"></column>
        </property>
        <property name="pathId" type="java.lang.Long">
            <column name="PATH_ID">
            </column>
        </property>
        <property name="togatherStatus" type="java.lang.Integer">
            <column name="TOGATHER_STATUS">
            </column>
        </property>

        <property name="pathContent" type="text">
            <column name="PATH_CONTENT">
            </column>
        </property>

        <property name="dataAuth" type="text">
            <column name="DATA_AUTH"></column>
        </property>
        <property name="updateTime" type="text">
            <column name="update_time"></column>
        </property>
        <property name="dataType" type="java.lang.Integer">
        	<column name="data_type"></column>
        </property>
        <property name="batchId" type="java.lang.String">
        	<column name="batch_id"></column>
        </property>
        <property name="ifLone" type="java.lang.Integer">
        	<column name="if_lone"></column>
        </property>
    </class>

</hibernate-mapping>