<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.iflytek.vie.app.pojo.report">
    <class name="com.iflytek.vie.app.pojo.report.ReportUsual" table="report_usual">
        <id name="id" type="int">
            <column name="id">
                <comment>id</comment>
            </column>
            <generator class="sequence">
                <param name="sequence">
                    reportusual_sequence
                </param>
            </generator>
        </id>
        <property name="createUser" type="string">
            <column name="createUser" length="64">
            </column>
        </property>
        <property name="reportId" type="int">
            <column name="reportId">
            </column>
        </property>
    </class>
</hibernate-mapping>