<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.iflytek.vie.app.pojo.dimension">
    <class name="DimensionTask" table="DIMENSION_TASK" >
        <id name="taskId" type="long">
            <column name="task_id">
                <comment>id</comment>
            </column>
            <generator class="sequence">
                <param name="sequence">
                    DIMENSION_TASK_SEQ
                </param>
            </generator>
        </id>
        <property name="taskName" type="string">
            <column name="task_name">
                <comment>文件名称</comment>
            </column>
        </property>
        <property name="message" type="text">
            <column name="message">
                <comment>处理消息</comment>
            </column>
        </property>
        <property name="taskState" type="int">
            <column name="task_state" not-null="true" default="0">
                <comment>任务转台</comment>
            </column>
        </property>
        <property name="createTime" type="string">
            <column name="create_time">
                <comment>创建时间</comment>
            </column>
        </property>
        <property name="updateTime">
            <column name="update_time">
                <comment>更新时间</comment>
            </column>
        </property>
        <property name="createName" type="string">
            <column name="create_name">
                <comment>创建人</comment>
            </column>
        </property>
        <set name="dpSet" lazy="false">
            <key>
                <column name="task_id">
                    <comment>模型组id</comment>
                </column>
            </key>
            <one-to-many class="DimensionPersonalTask"/>
        </set>
    </class>
</hibernate-mapping>