<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:context="http://www.springframework.org/schema/context"
	xmlns:aop="http://www.springframework.org/schema/aop" xmlns:mvc="http://www.springframework.org/schema/mvc"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
						http://www.springframework.org/schema/beans/spring-beans-4.0.xsd ">

	<bean id="serialService" class="com.iflytek.vie.app.provider.impl.serial.SerialServiceImpl">
		<property name="serialTaskDB" ref="serialTaskDB"/>
		<property name="serialDetailDB" ref="serialDetailDB"/>
		<property name="totalCount" value="5000"/>
		<property name="dimensionService" ref="dimensionService"/>
	</bean>

</beans>