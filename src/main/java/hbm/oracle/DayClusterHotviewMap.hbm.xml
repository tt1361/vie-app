<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.iflytek.vie.app.pojo.datamining">
    <class name="DayClusterHotviewMap"
           table="DAY_CLUSTER_HOTVIEW_MAP">
        <id name="id" type="java.lang.Long">
            <column name="ID">
                <comment>id</comment>
            </column>
            <generator class="sequence">
                <param name="sequence">
                    DAY_CLUSTER_HOTVIEW_MAP_SEQ
                </param>
            </generator>
        </id>
        <property name="clusterDate" type="java.lang.Long">
            <column name="CLUSTER_DATE"></column>
        </property>
        <property name="clusterList" type="text">
            <column name="CLUSTERLIST"></column>
        </property>
        <property name="sentence" type="text">
            <column name="SENTENCE" ></column>
        </property>
        <property name="createDate" type="java.util.Date">
            <column name="CREATEDATE">
            </column>
        </property>

        <property name="centerName" type="java.lang.String">
            <column name="CENTER_NAME"></column>
        </property>
        <property name="dataType" type="java.lang.Integer">
            <column name="data_type"></column>
        </property>
        <property name="batchId" type="java.lang.String">
            <column name="batch_id"></column>
        </property>
        <property name="ifLone" type="java.lang.Integer">
            <column name="if_lone"></column>
        </property>
        <property name="dataSource" type="java.lang.String">
            <column name="dataSource"></column>
        </property>

    </class>

</hibernate-mapping>