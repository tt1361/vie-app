<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.iflytek.vie.app.pojo.config">
    <class name="ModelCategory" table="MODEL_CATEGORY">
        <id name="id" type="long">
            <column name="id">
                <comment>id</comment>
            </column>
            <generator class="sequence">
                <param name="sequence">
                    MODEL_CATEGORY_SEQUENCE
                </param>
            </generator>
        </id>
        <property name="modelCategoryType" type="int">
            <column name="modelcategorytype">
                <comment>模型分类类型 1质检项 2业务项</comment>
            </column>
        </property>
        
        <property name="modelCategoryName" type="string">
            <column name="modelcategoryname">
                <comment>模型分类名称</comment>
            </column>
        </property>
        
        <property name="userId" type="long">
            <column name="createid">
                <comment>创建人id</comment>
            </column>
        </property>
        
        <property name="createdate">
            <column name="createdate">
                <comment>创建时间</comment>
            </column>
        </property>
        
        <property name="status" type="int">
            <column name="status">
                <comment>模型分类状态 0禁用 1启用</comment>
            </column>
        </property>
        
        <property name="description" type="string">
            <column name="description">
                <comment>备注描述</comment>
            </column>
        </property>

    </class>

</hibernate-mapping>