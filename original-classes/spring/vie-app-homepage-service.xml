<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:context="http://www.springframework.org/schema/context"
	xmlns:aop="http://www.springframework.org/schema/aop" xmlns:mvc="http://www.springframework.org/schema/mvc"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
						http://www.springframework.org/schema/beans/spring-beans-4.0.xsd">

	<bean id="customHomePageService" class="com.iflytek.vie.app.provider.impl.custom.CustomHomePageServiceImpl">
		<property name="dimPro" value="${dim}"/>
		<property name="dimName" value="${dimName}"/>
		<property name="dimProValue" value="${dimValue}"/>
		<property name="customHomePageDB" ref="customHomePageDB"/>
		<property name="excuteContext" ref="excuteContext"></property>
		<property name="dataSourceInfo" ref="dataSourceInfo"/>
		<property name="commonData" ref="commonData"/>
		<property name="modelApplyService" ref="ModelApply"/>
		<property name="sparkUtils" ref="sparkUtils"></property>
		<property name="dataAuthService" ref="dataAuthService"></property>
	</bean>

</beans>