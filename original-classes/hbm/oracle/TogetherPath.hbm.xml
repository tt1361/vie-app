<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC 
    "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
    "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping>

	<class name="com.iflytek.vie.app.pojo.datamining.TogetherPath" table="CALLREASON_TOGETHER_PATH">
		<id name="loadId" type="int">
			<column name="load_id" not-null="true"/>
			<generator class="sequence">
				<param name="sequence">
					CALLREASON_TOGETHER_PATH_SEQ
				</param>
			</generator>
		</id>
		<property name="loadIndex" type="string">
			<column name="load_index"/>
		</property>
		<property name="loadName" type="string">
			<column name="load_name"/>
		</property>
		<property name="taskId" type="long">
			<column name="task_id"/>
		</property>
		<property name="togetherId" type="int">
			<column name="together_id"/>
		</property>


	</class>
</hibernate-mapping>