<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.iflytek.vie.app.provider.pojo">
    <class name="StoreFileData" table="STORE_FILE_DATA">
        <id name="id" type="int">
            <column name="ID">
                <comment>主键</comment>
            </column>
            <generator class="sequence">
                <param name="sequence">
                    STORE_FILE_DATA_SEQUENCE
                </param>
            </generator>
        </id>
        <property name="fileName" type="java.lang.String">
            <column name="FILE_NAME">
                <comment>真实文件名</comment>
            </column>
        </property>
        <property name="fileFormat" type="java.lang.String">
            <column name="FILE_FORMAT">
                <comment>文件格式（后缀）</comment>
            </column>
        </property>
        <property name="fileSize" type="java.lang.Long">
            <column name="FILE_SIZE">
                <comment>文件大小</comment>
            </column>
        </property>
        <property name="storePath" type="java.lang.String">
            <column name="STORE_PATH">
                <comment>存储路径</comment>
            </column>
        </property>
        <property name="uploadDate" type="java.util.Date">
            <column name="UPLOAD_DATE">
                <comment>上传时间</comment>
            </column>
        </property>
        <property name="dataSource" type="java.lang.String">
            <column name="DATASOURCE">
                <comment>数据源</comment>
            </column>
        </property>
        <property name="status" type="java.lang.Integer">
            <column name="STATUS">
                <comment>处理状态（0：EPC成功、1：数据集成下载成功、2：数据集成下载中、-1：下载失败）
                		质检回传：（7：处理中,8：处理完成,9：处理失败）
                </comment>
            </column>
        </property>
    </class>
    
    <query name="getDataByFileId">
        from StoreFileData where id = ?
    </query>
</hibernate-mapping>