<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.iflytek.vie.app.pojo.download">
    <class name="com.iflytek.vie.app.pojo.download.CenterDownload" table="center_download">
        <id name="id" type="int">
            <column name="id">
                <comment>id</comment>
            </column>
            <generator class="sequence">
                <param name="sequence">
                    centerdownload_sequence
                </param>
            </generator>
        </id>
        <property name="createUser"  type="string">
            <column name="createUser" length="64">
            </column>
        </property>
        <property name="dataSource" type="string">
            <column name="dataSource" length="64">
            </column>
        </property>
        <property name="module" type="string">
            <column name="module" length="64">
            </column>
        </property>
        <property name="fileName" type="string">
            <column name="fileName" length="64">
            </column>
        </property>
        <property name="downloadDate" type="java.sql.Timestamp">
            <column name="downloadDate">
            </column>
        </property>
        <property name="fileSize" type="int">
            <column name="fileSize">
            </column>
        </property>
        <property name="progressRate" type="int">
            <column name="progressRate">
            </column>
        </property>
        <property name="trueFiledir" type="string">
            <column name="trueFiledir" length="500">
            </column>
        </property>

    </class>
</hibernate-mapping>