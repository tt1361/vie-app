<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.iflytek.vie.app.pojo.model">
    <class name="TagDimensionProperty" table="TAG_DIMENSION_PROPERTY">
        <id name="propertyId" type="long">
            <column name="property_id">
                <comment>id</comment>
            </column>
            <generator class="native"></generator>
        </id>
        <property name="propertyCode" type="string">
            <column name="property_code">
                <comment>标签属性CODE</comment>
            </column>
        </property>
        <property name="propertyName" type="string">
            <column name="property_name">
                <comment>标签属性名称</comment>
            </column>
        </property>
        <property name="isDepend" type="int">
            <column name="is_depend" default="0">
                <comment>是否有依赖</comment>
            </column>
        </property>
        <property name="flag" type="int">
            <column name="flag" default="0">
                <comment>0文本框或1下拉框</comment>
            </column>
        </property>
    </class>
</hibernate-mapping>